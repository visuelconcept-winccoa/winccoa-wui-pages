# =============================================================================
# WebUI Runtime Workspace .gitignore
#
# This workspace can be deployed standalone (without the monorepo root),
# so this file must be self-contained and not rely on a parent .gitignore.
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/

# -----------------------------------------------------------------------------
# Build output
# -----------------------------------------------------------------------------
dist/
dev-dist/
out-tsc/
*.tgz
*.tgz.bak
*.tar.gz
.license-cache.json

# -----------------------------------------------------------------------------
# Vite / Vitest
# -----------------------------------------------------------------------------
vite.config.*.timestamp*
vitest.config.*.timestamp*

# -----------------------------------------------------------------------------
# TypeScript
# -----------------------------------------------------------------------------
**/.tsbuildinfo

# -----------------------------------------------------------------------------
# Nx
# -----------------------------------------------------------------------------
**/.nx/cache
**/.nx/workspace-data
**/.nx/artifacts

# -----------------------------------------------------------------------------
# Test artifacts
# -----------------------------------------------------------------------------
coverage/
**/test-results/
**/*test-report.xml

# E2E (Playwright)
apps/*-e2e/*videos
apps/*-e2e/*screenshots
!apps/*-e2e/*screenshots/baseline
apps/*-e2e/playwright/.auth/
apps/*-e2e/test-results/
apps/*-e2e/src/downloads/
apps/*-e2e/coverage/

# NFR tests
apps/*-nfr/playwright/.auth/
apps/*-nfr/test-results/
apps/*-nfr/nfr-results/

# -----------------------------------------------------------------------------
# Build cache / generated intermediates
# -----------------------------------------------------------------------------
apps/dashboard-wc/scripts/.license-cache.json

# -----------------------------------------------------------------------------
# Environment & secrets
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
.npmrc
!standalone.npmrc

# -----------------------------------------------------------------------------
# IDE & editors
# -----------------------------------------------------------------------------
.idea/
.vs/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.sublime-workspace
*.launch
.project
.classpath
.c9/
.settings/

# AI assistant generated rules (auto-synced, not committed)
.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# -----------------------------------------------------------------------------
# OS files
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
npm-debug.log*
yarn-error.log*
yarn-debug.log*
pnpm-debug.log*

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
**/custom-elements.json
tmp/

# =============================================================================
# Scaffolded WebUI-runtime workspace — UN-VERSIONED
#
# `webui-runtime-init` (postinstall-webui-runtime.mjs) scaffolds the runtime
# workspace from @wincc-oa/webui-runtime, and `tools/wire-workspace.mjs`
# re-patches it. The repo tracks only the project's own deltas (libs/wui-*,
# backend modules, tools/wire-workspace.mjs + specs.json + deploy-backend.mjs,
# docs/wui-*). Everything below is regenerated by the scaffold and ignored.
# Per-subfolder where a whole directory is scaffolded; per-file for mixed dirs.
# (Already-tracked files are unaffected — .gitignore never un-tracks them.)
# =============================================================================

# --- App shell + runtime component library (fully scaffolded) ---
/apps/
/libs/default-components/

# --- Root build / tooling config (scaffolded) ---
/package.json
/package-lock.json
/project.json
/nx.json
/tsconfig.base.json
/tsconfig.base.tsbuildinfo
/vitest.workspace.ts
/.eslintrc.json
/.eslintrc-base.js
/.eslintignore
/.prettierrc
/.prettierignore
/.nycrc.json
/AGENTS.md

# --- Runtime helper scripts (mixed dir: deploy-backend.mjs is project-tracked) ---
/tools/scripts/init-oa-data.mjs
/tools/scripts/init-oa-data.spec.ts
/tools/scripts/deploy-oa-data.mjs
/tools/scripts/deploy-oa-data.spec.ts
/tools/scripts/postinstall-webui-runtime.mjs
/tools/scripts/postinstall-webui-runtime.spec.ts

# --- Scaffolded docs (knowledge base + diagrams) ---
/docs/knowledge/
/docs/diagrams/

# --- Scaffolded doc images (mixed dir: docs/images/manual/* is project-tracked) ---
/docs/images/oa-widget-external-model-viewer.png
/docs/images/oa-widget-step-by-step-example.png
/docs/images/temp-widget.svg

# --- Editor / AI-assistant skills & prompts (scaffolded) ---
/.github/prompts/
/.claude/skills/
/.ai/skills/
/.vscode/settings.json

# --- oa-data: only the scaffolded README (branding under oa-data/WebUI/ stays trackable) ---
/oa-data/README.md

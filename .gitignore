# =============================================================================
# WebUI Runtime Workspace .gitignore
#
# This workspace can be deployed standalone (without the monorepo root),
# so this file must be self-contained and not rely on a parent .gitignore.
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/

# -----------------------------------------------------------------------------
# Build output
# -----------------------------------------------------------------------------
dist/
dev-dist/
out-tsc/
*.tgz
*.tgz.bak
*.tar.gz
.license-cache.json

# -----------------------------------------------------------------------------
# Vite / Vitest
# -----------------------------------------------------------------------------
vite.config.*.timestamp*
vitest.config.*.timestamp*

# -----------------------------------------------------------------------------
# TypeScript
# -----------------------------------------------------------------------------
**/.tsbuildinfo

# -----------------------------------------------------------------------------
# Nx
# -----------------------------------------------------------------------------
**/.nx/cache
**/.nx/workspace-data
**/.nx/artifacts

# -----------------------------------------------------------------------------
# Test artifacts
# -----------------------------------------------------------------------------
coverage/
**/test-results/
**/*test-report.xml

# E2E (Playwright)
apps/*-e2e/*videos
apps/*-e2e/*screenshots
!apps/*-e2e/*screenshots/baseline
apps/*-e2e/playwright/.auth/
apps/*-e2e/test-results/
apps/*-e2e/src/downloads/
apps/*-e2e/coverage/

# NFR tests
apps/*-nfr/playwright/.auth/
apps/*-nfr/test-results/
apps/*-nfr/nfr-results/

# -----------------------------------------------------------------------------
# Build cache / generated intermediates
# -----------------------------------------------------------------------------
apps/dashboard-wc/scripts/.license-cache.json

# -----------------------------------------------------------------------------
# Environment & secrets
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
.npmrc
!standalone.npmrc

# -----------------------------------------------------------------------------
# IDE & editors
# -----------------------------------------------------------------------------
.idea/
.vs/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.sublime-workspace
*.launch
.project
.classpath
.c9/
.settings/

# AI assistant generated rules (auto-synced, not committed)
.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# -----------------------------------------------------------------------------
# OS files
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
npm-debug.log*
yarn-error.log*
yarn-debug.log*
pnpm-debug.log*

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
**/custom-elements.json
tmp/

# -----------------------------------------------------------------------------
# Third-party IP — MUST NOT be published under this project's license.
# (See IP_AUDIT.md. Kept out of the open-source repo; not authored by Visuel Concept.)
# -----------------------------------------------------------------------------
# WinCC OA project archive: contains Siemens/WinCC-OA-SDK-derived .ctl scripts,
# GEDI panels and a WinCC OA logo. Referenced only in comments (legacy model).
/winccoa_projectmanager.zip
# Industrial symbol set of third-party origin (replace with original/licensed art).
/apps/dashboard-wc/public/semifab-icons/
# ETM WinCC OA MCP server (ISC) — consume via npm @etm-professional-control/winccoa-mcp-server,
# do not re-vendor it into the repo.
/backend/managers/mcpServer/

# =============================================================================
# Scaffolded WebUI-runtime workspace — PARTIAL ignore
#
# `webui-runtime-init` scaffolds the runtime workspace and `wire-workspace.mjs`
# re-patches it. We can ONLY ignore scaffold files that NX DOES NOT READ:
# nx EXCLUDES .gitignored paths from its project graph, so apps/, libs/*,
# nx.json, package.json, project.json, tsconfig.base.json (and the eslint/
# prettier/vitest configs) MUST stay visible — ignoring them breaks `nx build`
# ("Cannot find project 'dashboard-wc'"). Those scaffold files therefore remain
# untracked; commit them if you want a fully clean `git status`.
#
# Only docs / skills / editor / build-artifact scaffold (not read by nx) below.
# Already-tracked files are unaffected — .gitignore never un-tracks them.
# =============================================================================

# Build artifact (regenerated by tsc)
/tsconfig.base.tsbuildinfo

# Scaffolded docs (knowledge base + diagrams)
/docs/knowledge/
/docs/diagrams/

# Scaffolded doc images (the per-page manual images, docs/images/manual/*, stay tracked)
/docs/images/oa-widget-external-model-viewer.png
/docs/images/oa-widget-step-by-step-example.png
/docs/images/temp-widget.svg

# Editor / AI-assistant skills & prompts (scaffolded)
/.github/prompts/
/.claude/skills/
/.ai/skills/
/.vscode/settings.json

# Runtime helper scripts (scaffolded; not read by nx)
/tools/scripts/init-oa-data.mjs
/tools/scripts/init-oa-data.spec.ts
/tools/scripts/deploy-oa-data.mjs
/tools/scripts/deploy-oa-data.spec.ts
/tools/scripts/postinstall-webui-runtime.mjs
/tools/scripts/postinstall-webui-runtime.spec.ts

# oa-data: only the scaffolded README (branding under oa-data/WebUI/ stays trackable)
/oa-data/README.md

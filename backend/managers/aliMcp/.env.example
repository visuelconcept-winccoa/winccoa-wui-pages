# Asset Lifecycle Intelligence MCP server — runtime config (copy to .env)
# Port the Streamable-HTTP MCP endpoint listens on (default 3100).
ALI_MCP_PORT=3100
# Bind host (default 0.0.0.0). Use 127.0.0.1 to restrict to localhost.
ALI_MCP_HOST=0.0.0.0
# Optional Bearer token. If set, clients must send "Authorization: Bearer <token>".
# Leave unset to disable authentication (localhost-only deployments).
ALI_MCP_TOKEN=

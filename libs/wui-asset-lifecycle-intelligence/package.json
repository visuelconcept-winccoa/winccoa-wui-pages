{
  "name": "@visuelconcept/wui-asset-lifecycle-intelligence",
  "type": "module",
  "version": "0.1.0",
  "description": "Asset Lifecycle Intelligence — standalone WinCC OA WebUI page: industrial asset inventory with a composite obsolescence/risk score, KPI bar + risk-ranked table, JSON/CSV + TIA AML import, optional Siemens PIH lookup and an AI assistant. One datapoint per asset.",
  "author": { "name": "Visuel Concept" },
  "keywords": ["OpenArchitecture", "WinCCOA", "dashboard", "webcomponents", "standalone-page"],
  "license": "MIT",
  "dependencies": {
    "@visuelconcept/wui-kit": "*",
    "@visuelconcept/wui-ai-kit": "*"
  },
  "peerDependencies": {
    "lit": "*",
    "rxjs": "*",
    "tsyringe": "*",
    "@etm-professional-control/oa-rx-js-api": "*",
    "@wincc-oa/wui-shared": "*",
    "@wincc-oa/wui-data-selector-data": "*",
    "@wincc-oa/wui-ix-wrappers": "*",
    "@wincc-oa/wui-oarxjs-context": "*"
  },
  "exports": { "./*": { "types": "./types/*", "import": "./*" } },
  "wuiPage": {
    "route": "/asset-lifecycle",
    "routeId": "asset-lifecycle",
    "component": "wui-asset-lifecycle",
    "module": "/data/dashboard-wc/pages/asset-lifecycle-intelligence.js",
    "icon": "cycle",
    "permission": ["connected"],
    "tier": 1,
    "backend": {
      "managers": ["productInfo (optional, Siemens PIH lookup)", "aiAssistant (optional, via wui-ai-kit)"],
      "routes": ["/api/product-info/lookup (optional)", "/api/ai/chat (optional)"]
    }
  }
}

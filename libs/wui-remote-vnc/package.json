{
  "name": "@visuelconcept/wui-remote-vnc",
  "type": "module",
  "version": "0.1.0",
  "description": "Remote VNC — standalone WinCC OA WebUI page: manage VNC connections (one RemoteVnc_Connection datapoint each) and open a session in-browser via bundled noVNC over a same-origin /api/vnc/ws relay.",
  "author": { "name": "Visuel Concept" },
  "keywords": ["OpenArchitecture", "WinCCOA", "dashboard", "webcomponents", "standalone-page"],
  "license": "MIT",
  "dependencies": {
    "@visuelconcept/wui-kit": "*"
  },
  "peerDependencies": {
    "lit": "*",
    "rxjs": "*",
    "tsyringe": "*",
    "@etm-professional-control/oa-rx-js-api": "*",
    "@wincc-oa/wui-ix-wrappers": "*",
    "@wincc-oa/wui-oarxjs-context": "*",
    "@wincc-oa/wui-shared": "*",
    "@wincc-oa/wui-models": "*",
    "@wincc-oa/wui-data-selector-data": "*",
    "@novnc/novnc": "*"
  },
  "exports": {
    "./*": {
      "types": "./types/*",
      "import": "./*"
    }
  },
  "wuiPage": {
    "route": "/remote-vnc",
    "routes": ["/remote-vnc", "/remote-vnc/:connectionid"],
    "routeId": "remote-vnc",
    "component": "wui-remote-vnc",
    "module": "/data/dashboard-wc/pages/remote-vnc.js",
    "icon": "monitor",
    "permission": ["connected"],
    "tier": 3,
    "backend": {
      "managers": ["vncProxy (MSA vRPC: resolves connection id -> host:port from RemoteVnc_ DPs)"],
      "routes": ["/api/vnc/* + the /api/vnc/ws raw ws<->TCP relay (websockify-style)"]
    }
  }
}
